<Window x:Class="EvidenceGuard.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:conv="clr-namespace:EvidenceGuard.Converters"
        prism:ViewModelLocator.AutoWireViewModel="True"
        Title="Evidence Guard - Forensic Tool (Benchmarked on MD-NEXT)" Height="750" Width="850">

    <Window.Resources>
        <conv:HashTypeToEnabledConverter x:Key="HashTypeToEnabledConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="증거 파일 선택" Margin="0,0,0,10">
            <DockPanel Margin="5">
                <Button Content="찾아보기..." Command="{Binding SelectFileCommand}" DockPanel.Dock="Right" Width="100" Margin="5,0,0,0"/>
                <TextBox Text="{Binding FilePath}" IsReadOnly="True" VerticalContentAlignment="Center"/>
            </DockPanel>
        </GroupBox>

        <GroupBox Header="교차 검증 알고리즘 설정" Grid.Row="1" Margin="0,0,0,10">
            <UniformGrid Columns="2" Margin="5">
                <StackPanel Margin="5">
                    <TextBlock Text="알고리즘 1" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{Binding HashAlgorithms}" SelectedItem="{Binding SelectedHash1}">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="IsEnabled">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource HashTypeToEnabledConverter}">
                                            <Binding Path="."/>
                                            <Binding Path="DataContext.SelectedHash2" RelativeSource="{RelativeSource AncestorType=Window}" />
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                </StackPanel>
                <StackPanel Margin="5">
                    <TextBlock Text="알고리즘 2" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{Binding HashAlgorithms}" SelectedItem="{Binding SelectedHash2}">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="IsEnabled">
                                    <Setter.Value>
                                        <MultiBinding Converter="{StaticResource HashTypeToEnabledConverter}">
                                            <Binding Path="."/>
                                            <Binding Path="DataContext.SelectedHash1" RelativeSource="{RelativeSource AncestorType=Window}" />
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>
                </StackPanel>
            </UniformGrid>
        </GroupBox>

        <GroupBox Header="분석 결과 및 상태" Grid.Row="2" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Hash 1 결과" Grid.Column="0" Margin="5,0"/>
                <TextBox Text="{Binding Hash1Result}" IsReadOnly="True" Grid.Row="1" Grid.Column="0" Margin="5"/>

                <TextBlock Text="Hash 2 결과" Grid.Column="1" Margin="5,0"/>
                <TextBox Text="{Binding Hash2Result}" IsReadOnly="True" Grid.Row="1" Grid.Column="1" Margin="5"/>

                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="5">
                    <TextBlock Text="현재 작업: " FontWeight="Bold"/>
                    <TextBlock Text="{Binding Status}" Foreground="#005A9E" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <GroupBox Header="선별적 증거 추출 목록" Grid.Row="3" Margin="0,0,0,10">
            <DataGrid ItemsSource="{Binding ExtractionResults}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True"
                      VerticalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="파일명" Binding="{Binding FileName}" Width="150"/>
                    <DataGridTextColumn Header="라인" Binding="{Binding LineNumber}" Width="50"/>
                    <DataGridTextColumn Header="유형" Binding="{Binding TypeName}" Width="80"/>
                    <DataGridTextColumn Header="데이터(키워드)" Binding="{Binding Keyword}" Width="*"/>
                    <DataGridTextColumn Header="오프셋" Binding="{Binding Offset}" Width="80"/>
                    <DataGridTextColumn Header="시간" Binding="{Binding FoundTime, StringFormat=\{0:HH:mm:ss\}}" Width="80"/>
                    <DataGridCheckBoxColumn Header="무결성" Binding="{Binding IsIntegrityVerified}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Grid Grid.Row="4" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="보안 획득 (암호화)" 
                    Command="{Binding RunAcquisitionCommand}" 
                    Height="50" Margin="0,0,5,0"
                    FontSize="13" FontWeight="Bold" Background="#F3F3F3"/>

            <Button Grid.Column="1" Content="복원 및 분석" 
                    Command="{Binding RunRestitutionCommand}" 
                    Height="50" Margin="5,0,5,0"
                    FontSize="13" FontWeight="Bold" Background="#F3F3F3"/>

            <Button Grid.Column="2" Content="리포트 저장" 
                    Command="{Binding SaveReportCommand}" 
                    Height="50" Margin="5,0,0,0"
                    FontSize="13" FontWeight="Bold" Background="#F3F3F3"/>
        </Grid>

        <StatusBar Grid.Row="5" Background="#F0F0F0" BorderBrush="#DCDCDC" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="CPU:" Margin="5,0,2,0" Foreground="#555"/>
                    <TextBlock Text="{Binding CpuUsage, StringFormat={}{0:F1}%}" Width="45" FontWeight="SemiBold"/>
                </StackPanel>
            </StatusBarItem>
            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Available RAM:" Margin="5,0,2,0" Foreground="#555"/>
                    <TextBlock Text="{Binding RamUsage, StringFormat={}{0:N0} MB}" Width="70" FontWeight="SemiBold"/>
                </StackPanel>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="System Ready" Foreground="#666" Margin="0,0,10,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>